# Firebase Configuration
# Option 1: Use firebase-key.json file (recommended)
# Place your Firebase service account JSON file as firebase-key.json in the backend root directory

# Option 2: Use environment variables (if firebase-key.json doesn't exist)
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_PRIVATE_KEY=your-private-key-with-escaped-newlines
FIREBASE_CLIENT_EMAIL=your-email@project.iam.gserviceaccount.com

# Firebase Web API Key (for Firebase Auth REST API)
# Get from Firebase Console > Project Settings > Web API Key
FIREBASE_WEB_API_KEY=your-web-api-key

NODE_ENV=development
PORT=3000
